@{
    ViewData["Title"] = "Register";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-success">Create Account</h2>
                        <p class="text-muted">Register for professional licensing</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <form asp-controller="Auth" asp-action="Register" method="post">
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Username</label>
                                <input type="text" name="username" class="form-control" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Password</label>
                                <input type="password" name="password" class="form-control" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Access Level (Role)</label>
                            <select name="role" id="roleSelect" class="form-select form-select-lg" onchange="toggleAgency()" required>
                                <option value="Applicant">Applicant (Individual Professional)</option>
                                <option value="Agency">Agency (Department Admin)</option>
                                <option value="Admin">Admin (State Super User)</option>
                            </select>
                        </div>

                        <div class="mb-4" id="agencyDiv" style="display:none;">
                            <label class="form-label fw-semibold text-primary">Assigned Regulatory Board</label>
                            <select name="agency" class="form-select form-select-lg">
                                <option value="">-- Choose Board --</option>
                                <option value="Medical Licensing Board">Medical Licensing Board</option>
                                <option value="Board of Nursing">Board of Nursing</option>
                                <option value="Professional Engineering Council">Professional Engineering Council</option>
                                <option value="State Bar Association">State Bar Association</option>
                                <option value="Real Estate Commission">Real Estate Commission</option>
                            </select>
                            <small class="text-muted">Agency users only see data for their selected board.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">State/Tenant ID</label>
                            <input type="text" name="tenantId" class="form-control" required value="tenant1" />
                        </div>

                        <div class="d-grid gap-2 mb-4">
                            <button type="submit" class="btn btn-success btn-lg">Complete Registration</button>
                        </div>
                        <div class="text-center">
                            <p class="mb-0">Already registered? <a asp-controller="Auth" asp-action="Login" class="text-success fw-bold text-decoration-none">Access your account</a></p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleAgency() {
        var role = document.getElementById("roleSelect").value;
        document.getElementById("agencyDiv").style.display = (role === "Agency") ? "block" : "none";
    }
</script>
