@model List<LicenseFrontend.Models.LicenseViewModel>
@{
    ViewData["Title"] = "State Management Dashboard";
    var userRole = User.IsInRole("Admin") ? "State Admin" : "Agency Admin";
}

<div class="row mb-4">
    <div class="col-md-12">
        <div class="d-flex justify-content-between align-items-center bg-white p-4 rounded shadow-sm">
            <div>
                <h2 class="fw-bold text-dark mb-0">@userRole Dashboard</h2>
                <p class="text-muted mb-0">
                    Regulatory oversight for <span class="badge bg-secondary">@User.FindFirst("TenantId")?.Value</span>
                    @if (User.IsInRole("Agency"))
                    {
                        <span> | Agency: <span class="badge bg-info">@User.FindFirst("Agency")?.Value</span></span>
                    }
                </p>
            </div>
            <div class="text-end">
                <span class="text-muted small">Logged in as:</span><br />
                <span class="fw-bold">@User.Identity?.Name</span>
            </div>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-header border-0 pt-4 px-4">
        <h5 class="fw-bold mb-0">Pending Regulatory Reviews</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="px-4">Applicant</th>
                        <th>License Number</th>
                        <th>Agency Board</th>
                        <th>Status</th>
                        <th class="text-center">Review Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 fw-semibold">@item.ApplicantName</td>
                                <td>
                                    <code class="text-primary fw-bold">@item.LicenseNumber</code>
                                </td>
                                <td>@item.Agency</td>
                                <td>
                                    <span class="badge status-@item.Status">@item.Status</span>
                                    @if (item.DocumentId.HasValue)
                                    {
                                        <div class="mt-1">
                                            <a asp-controller="Licenses" asp-action="DownloadDocument" asp-route-id="@item.DocumentId.Value" class="btn btn-link btn-sm p-0 text-decoration-none" style="font-size: 0.75rem;" title="@item.DocumentFileName">
                                                📂 @(item.DocumentFileName ?? "Download File")
                                            </a>
                                        </div>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.Status == "Pending")
                                    {
                                        <div class="btn-group">
                                            <form asp-controller="Licenses" asp-action="UpdateStatus" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="status" value="Approved" />
                                                <button type="submit" class="btn btn-sm btn-success me-2 px-3">Approve</button>
                                            </form>
                                            <form asp-controller="Licenses" asp-action="UpdateStatus" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="status" value="Rejected" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger px-3">Reject</button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small italic">Finalized</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <p class="text-muted">No license applications are currently awaiting review.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-4 text-center">
    <small class="text-muted">GovLicense System | State Regulatory Compliance V1.0</small>
</div>
